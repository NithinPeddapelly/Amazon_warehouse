NODE_ENV=development
PORT=4000
DATABASE_URL="file:./dev.db"
SCRAPE_INTERVAL=10
SCRAPE_TIMEOUT_MS=20000
SCRAPE_MAX_RETRIES=2
SCRAPE_RENDER_TIMEOUT_MS=30000
SCRAPE_USE_PLAYWRIGHT=true
GRAPHQL_ENDPOINT="https://www.jobsatamazon.co.uk/graphql"
GRAPHQL_LOCALE="en-GB"
GRAPHQL_SEARCH_LIMIT=75
GRAPHQL_AUTH_HEADER=
GRAPHQL_AUTH_VALUE=
BOT_TOKEN=YOUR_BOT_TOKEN
CHAT_ID=YOUR_CHAT_ID
AMAZON_JOBS_URL="https://www.jobsatamazon.co.uk/app#/jobSearch?query=&postal=&locale=en-GB"
SCRAPE_PROXY_URL=
SCRAPE_ACCEPT_LANGUAGE="en-GB,en;q=0.9"
KEYWORD_FILTER="warehouse"
LOCATION_FILTER="scotland,bathgate,dunfermline,livingston,edinburgh,glasgow"
MIN_SALARY_PER_HOUR=0
WORK_TYPE_FILTER="part-time,seasonal"
